# Doctigo Timeguard — Environment Variables
# Copy this to .env and fill your values. NEVER commit .env to git.

# PostgreSQL — get a free DB from neon.tech
DATABASE_URL=postgresql://user:password@host/timeguard_db?sslmode=require

# JWT Secret — use a long random string (64+ characters)
JWT_SECRET=change-this-to-a-very-long-random-string-minimum-64-chars

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=3000
NODE_ENV=development

# CORS — in production set to your Vercel URL e.g. https://doctigo-timeguard.vercel.app
ALLOWED_ORIGIN=*
